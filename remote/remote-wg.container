[Unit]
Description=Easy Wireguard server

[Service]
ExecStartPre=sh remote/remote-wg.bootstrap

[Container]
Image=ghcr.io/wg-easy/wg-easy

ContainerName=wireguard
AutoUpdate=registry
Pod=remote.pod

AddCapability=NET_ADMIN
AddCapability=SYS_MODULE
AddCapability=NET_RAW

Environment=WG_HOST=${DOMAIN}
Environment=WG_DEFAULT_DNS=${IP_ADDRESS}
Environment=DISABLE_IPV6=true

Sysctl=net.ipv4.ip_forward=1
Sysctl=net.ipv4.conf.all.src_valid_mark=1

Volume=${VOLUMES_DIR}/wireguard:/etc/wireguard
