[Unit]
Description=Vaultwarden server

[Service]
Restart=no
RestartSec=10

TimeoutStartSec=${CONTAINER_START_TIMEOUT}
ExecStart=sh vaultwarden.bootstrap

[Container]
Image=docker.io/vaultwarden/server
ContainerName=vaultwarden

AutoUpdate=registry
NoNewPrivileges=true
UserNS=${USER_NAMESPACE}

Network=caddy.network

Environment=SIGNUPS_ALLOWED=false
Environment=INVITATIONS_ALLOWED=false
Environment=ROCKET_PORT=8080

Volume=${VOLUME_DIR}/vaultwarden:/data

[Install]
WantedBy=default.target
