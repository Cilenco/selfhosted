[Unit]
Description=HomeAssistant Server

[Service]
Restart=no
RestartSec=10
TimeoutStartSec={{ container_start_timeout }}

[Container]
Image=docker.io/cilenco/homeassistant
ContainerName={{ container_name }}

AutoUpdate=registry
NoNewPrivileges=true
UserNS={{ user_ns }}
#GroupsAdd=dialout

Network=caddy.network

Volume={{ volumes }}/{{ container_name }}:/config

Volume=/etc/localtime:/etc/localtime:ro
AddDevice=-/dev/ttyUSB0:/dev/ttyUSB0

[Install]
WantedBy=default.target
