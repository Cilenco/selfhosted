[Unit]
Description=Immich ML server

[Service]
Restart=no
RestartSec=10
TimeoutStartSec=300

[Container]
Image=ghcr.io/immich-app/immich-machine-learning:release

ContainerName=immich-ml

AutoUpdate=registry
NoNewPrivileges=true

Network=caddy.network

Volume=immich-ml:/cache

[Install]
WantedBy=default.target
