[Unit]
Description=OxiCloud database

[Service]
ExecStartPre=sh oxicloud/oxicloud-db.bootstrap

[Container]
Image=docker.io/postgres

ContainerName=oxicloud-db
AutoUpdate=registry
Pod=oxicloud.pod

HealthCmd=pg_isready
HealthStartPeriod=1m20s
HealthInterval=30s
HealthTimeout=30s
HealthRetries=3

Environment=POSTGRES_USER=postgres
Environment=POSTGRES_PASSWORD=postgres
Environment=POSTGRES_DB=oxicloud

Volume=${VOLUMES_DIR}/oxicloud/db/data:/var/lib/postgresql:idmap
