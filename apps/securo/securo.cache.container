[Unit]
Description=Securo Redis

[Service]
ExecStartPre=sh securo/securo.cache.bootstrap

[Container]
Image=docker.io/redis
Pod=securo.app.pod

ContainerName=securo-redis
AutoUpdate=registry

HealthCmd="redis-cli ping | grep PONG"
HealthStartPeriod=1m20s
HealthInterval=30s
HealthTimeout=30s
HealthRetries=3

Volume=${VOLUMES_DIR}/securo/cache/data:/data
