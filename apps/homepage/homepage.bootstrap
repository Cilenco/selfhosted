#!/bin/bash

mkdir -p $VOLUMES_DIR/homepage

(envsubst < $PWD/homepage/config/services.yaml) > $VOLUMES_DIR/homepage/services.yaml
(envsubst < $PWD/homepage/config/bookmarks.yaml) > $VOLUMES_DIR/homepage/bookmarks.yaml
(envsubst < $PWD/homepage/config/settings.yaml) > $VOLUMES_DIR/homepage/settings.yaml
(envsubst < $PWD/homepage/config/widgets.yaml) > $VOLUMES_DIR/homepage/widgets.yaml
(envsubst < $PWD/homepage/config/custom.css) > $VOLUMES_DIR/homepage/custom.css
