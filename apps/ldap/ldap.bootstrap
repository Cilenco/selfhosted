#!/bin/bash

mkdir -p $VOLUMES_DIR/ldap/data

printf $(openssl rand -hex 64) | podman secret create LDAP_JWT_KEY -  | true
printf $(openssl rand -hex 64) | podman secret create LDAP_USERNAME - | true
printf $(openssl rand -hex 64) | podman secret create LDAP_PASSWORD - | true
printf $(openssl rand -hex 64) | podman secret create LDAP_KEY_SEED - | true