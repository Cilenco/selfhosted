#!/bin/bash

mkdir -p $VOLUMES_DIR/ldap

openssl rand -hex 64 | podman secret create LDAP_JWT_KEY -  | true
openssl rand -hex 64 | podman secret create LDAP_USERNAME - | true
openssl rand -hex 64 | podman secret create LDAP_PASSWORD - | true
openssl rand -hex 64 | podman secret create LDAP_KEY_SEED - | true