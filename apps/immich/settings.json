{
  "server": {
    "externalDomain": "https://photos.${DOMAIN}"
  },
  "logging": {
    "enabled": true,
    "level": "log"
  },
  "storageTemplate": {
    "enabled": true,
    "template": "Fotos/{{y}}-{{MM}}/{{filename}}",
    "hashVerificationEnabled": true
  },
  "passwordLogin": {
    "enabled": true
  },
  "machineLearning": {
    "urls": ["http://localhost:3003"]
  },
  "oauth": {
    "enabled": true,
    "autoLaunch": true,
    "autoRegister": true,
    "buttonText": "Login with Authelia",
    "issuerUrl": "https://auth.${DOMAIN}/.well-known/openid-configuration",
    "clientSecret": "",
    "clientId": "immich",
    "defaultStorageQuota": null,
    "mobileOverrideEnabled": false,
    "mobileRedirectUri": "",
    "storageLabelClaim": "preferred_username",
    "scope": "openid email profile"
  },
  "newVersionCheck": {
    "enabled": false
  },
  "trash": {
    "enabled": true,
    "days": 30
  }
}
