[Unit]
Description=Outline Redis

[Service]
ExecStartPre=sh outline/outline.cache.bootstrap

[Container]
Image=docker.io/redis

ContainerName=outline-redis
AutoUpdate=registry
Network=caddy

HealthCmd="redis-cli ping | grep PONG"
HealthStartPeriod=1m20s
HealthInterval=30s
HealthTimeout=30s
HealthRetries=3

Volume=${VOLUMES_DIR}/outline/cache/data:/data
