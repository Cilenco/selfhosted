[Unit]
Description=Nextcloud cache

[Service]
ExecStartPre=sh nextcloud/nextcloud-cache.bootstrap

[Container]
Image=docker.io/redis

ContainerName=nextcloud-cache
AutoUpdate=registry
Pod=nextcloud.pod

HealthCmd="redis-cli | grep PONG"
HealthStartPeriod=1m20s
HealthInterval=30s
HealthTimeout=30s
HealthRetries=3

Volume=${VOLUMES_DIR}/nextcloud/cache:/data:idmap
