[Unit]
Description=Nextcloud Server

[Service]
ExecStartPre=sh nextcloud/nextcloud-srv.bootstrap

[Container]
Image=docker.io/nginxinc/nginx-unprivileged:alpine-slim

ContainerName=nextcloud-srv
AutoUpdate=registry
Pod=nextcloud.pod

Volume=${VOLUMES_DIR}/nextcloud/app:/var/www/html:ro
Volume=./nginx.conf:/etc/nginx/nginx.conf:ro
