[Unit]
Description=SparkyFitness database

[Service]
ExecStartPre=sh fitness/fitness-db.bootstrap

[Container]
Image=docker.io/postgres

ContainerName=fitness-db
AutoUpdate=registry
Pod=fitness.pod

HealthCmd=pg_isready
HealthStartPeriod=1m20s
HealthInterval=30s
HealthTimeout=30s
HealthRetries=3

Environment=POSTGRES_USER=postgres
Environment=POSTGRES_PASSWORD=postgres
Environment=POSTGRES_DB=fitness

Volume=${VOLUMES_DIR}/fitness/db/data:/var/lib/postgresql
