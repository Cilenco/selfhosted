[Unit]
Description=Jellyfin streming server

[Service]
ExecStartPre=sh jellyfin/jellyfin.bootstrap

[Container]
Image=docker.io/jellyfin/jellyfin

HostName=jellyfin
ContainerName=jellyfin
AutoUpdate=registry
Network=caddy

Volume=${VOLUMES_DIR}/jellyfin/cache:/cache
Volume=${VOLUMES_DIR}/jellyfin/config:/config

Volume=${MEDIA_DIR}:/media:ro
