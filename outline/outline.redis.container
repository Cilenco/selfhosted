[Unit]
Description=Outline Redis

[Service]
Restart=no
RestartSec=10
TimeoutStartSec=300

[Container]
Image=docker.io/redis
ContainerName=outline-redis

Pod=outline.pod

AutoUpdate=registry
NoNewPrivileges=true
User=redis:redis

HealthCmd="redis-cli ping | grep PONG"
HealthStartPeriod=1m20s
HealthInterval=30s
HealthTimeout=30s
HealthRetries=3

Volume=outline.redis.volume:/data

[Install]
WantedBy=default.target
